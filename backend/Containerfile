FROM docker.io/library/python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /srv/backend

COPY backend/pyproject.toml /srv/backend/pyproject.toml
COPY backend/alembic.ini /srv/backend/alembic.ini
COPY backend/alembic /srv/backend/alembic
COPY backend/app /srv/backend/app
COPY backend/docker-entrypoint.sh /srv/backend/docker-entrypoint.sh
COPY backend/scripts /srv/backend/scripts
COPY assets /srv/assets

RUN pip install --upgrade pip \
    && pip install . \
    && chmod +x /srv/backend/docker-entrypoint.sh

EXPOSE 8000

CMD ["/srv/backend/docker-entrypoint.sh"]
